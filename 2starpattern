// code : to print this pattern:
class Solution {
    public void pattern1(int n) {
        for (int i = 0; i < n; i++) {          
            for (int j = 0; j < n; j++) {      
                System.out.print("*");         
            }
            System.out.println();              
        }
    }
}

class Main {
    public static void main(String[] args) {
        int n = 2;
        Solution sol = new Solution();
        sol.pattern1(n);
    }
}
